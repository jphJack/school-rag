# ==================== LLM 配置 ====================
# DeepSeek API (推荐，性价比高)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API (备选)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ==================== Embedding 配置 ====================
# 选择嵌入模型: bge-local | openai
EMBEDDING_PROVIDER=bge-local
# BGE模型名称 (本地运行)
BGE_MODEL_NAME=BAAI/bge-large-zh-v1.5
# OpenAI Embedding (如选择openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==================== 向量数据库 ====================
CHROMA_PERSIST_DIR=./data/chroma

# ==================== 爬虫配置 ====================
# 爬取请求间隔(秒)
CRAWL_DELAY=2
# 爬取深度
CRAWL_DEPTH=2
# 并发请求数
CRAWL_CONCURRENT=4
# 是否遵守robots.txt
CRAWL_ROBOTS_TXT=true
# User-Agent
CRAWL_USER_AGENT=SchoolRAG-Bot/1.0 (+https://github.com/school-rag)

# ==================== 数据存储 ====================
RAW_DATA_DIR=./data/raw
METADATA_DB=./data/metadata.db

# ==================== API配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ==================== 日志 ====================
LOG_LEVEL=INFO
